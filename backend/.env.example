# Copy to .env.development (local) or .env.production (prod simulation / reference for Render).
#   cp .env.example .env.development

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_ORIGIN=http://localhost:3000

RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Autonomous Scheduling Platform
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USERNAME=resend
RESEND_MIN_INTERVAL_SECONDS=60

REDIS_URL=redis://localhost:6379/0
UPSTASH_REDIS_URL=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_ZERO_DATA_RETENTION=true

BAA_ENFORCEMENT=true
ENVIRONMENT=development
DEBUG=false
