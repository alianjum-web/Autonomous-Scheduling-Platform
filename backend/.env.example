# See .env.development for local dev. Copy to .env.production for prod simulation
# (gitignored) or set the same keys in Render environment variables.
# Quick start: make env-dev  &&  edit backend/.env with your secrets

# URL = https://<Project-ID>.supabase.co  (Project ID is on Settings → General)
SUPABASE_URL=https://your-project.supabase.co
# Settings → API Keys → Secret keys → Reveal (sb_secret_... or legacy service_role JWT)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → JWT Keys → Legacy JWT Secret → Reveal (HS256 fallback; JWKS used for ECC tokens)
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_ORIGIN=http://localhost:3000
# Production: Upstash serverless Redis (rediss:// enables TLS automatically)
UPSTASH_REDIS_URL=
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o
# Requires OpenAI BAA + org-level Zero Data Retention before real PHI
OPENAI_ZERO_DATA_RETENTION=true
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
SENTRY_DSN=
ENVIRONMENT=development
DEBUG=false
# Log policy metadata (enforce retention/access at aggregator — Railway, Grafana Cloud, etc.)
LOG_RETENTION_DAYS=30
LOG_ACCESS_CLASS=restricted_ops

# Observability (Grafana Cloud scrapes GET /metrics)
# SENTRY_DSN is listed above — PHI scrubbed before upload
