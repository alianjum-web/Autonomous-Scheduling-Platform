SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_ORIGIN=http://localhost:3000
# Production: Upstash serverless Redis (rediss:// enables TLS automatically)
UPSTASH_REDIS_URL=
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o
# Requires OpenAI BAA + org-level Zero Data Retention before real PHI
OPENAI_ZERO_DATA_RETENTION=true
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
SENTRY_DSN=
ENVIRONMENT=development
DEBUG=false

# Observability (Grafana Cloud scrapes GET /metrics)
# SENTRY_DSN is listed above — PHI scrubbed before upload
