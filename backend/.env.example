# See .env.development for local dev. Copy to .env.production for prod simulation
# (gitignored) or set the same keys in Render environment variables.
# Quick start: make env-dev  &&  edit backend/.env with your secrets

# URL = https://<Project-ID>.supabase.co  (Project ID is on Settings → General)
SUPABASE_URL=https://your-project.supabase.co
# Settings → API Keys → Publishable key (same value as frontend NEXT_PUBLIC_SUPABASE_ANON_KEY)
SUPABASE_ANON_KEY=your-anon-key
# Settings → API Keys → Secret keys → Reveal (sb_secret_... or legacy service_role JWT)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Settings → JWT Keys → Legacy JWT Secret → Reveal (HS256 fallback; JWKS used for ECC tokens)
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_ORIGIN=http://localhost:3000

# ── Resend (https://resend.com/docs/send-with-supabase-smtp) ──────────────────
# Auth emails: configure Supabase SMTP with these values (make resend-smtp)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Autonomous Scheduling Platform
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USERNAME=resend
RESEND_MIN_INTERVAL_SECONDS=60

# Production: Upstash serverless Redis (rediss:// enables TLS automatically)
UPSTASH_REDIS_URL=
REDIS_URL=redis://localhost:6379/0

# --- AI providers (keys optional — use Ollama locally for free) ---
# Active provider is set in backend/feature-flags.json (hot-reloads on change)
FEATURE_FLAGS_PATH=
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
# Requires OpenAI BAA + org-level Zero Data Retention before real PHI
OPENAI_ZERO_DATA_RETENTION=true
OLLAMA_BASE_URL=http://localhost:11434/v1
GEMINI_API_KEY=
GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1

# HIPAA BAA gate — blocks AI triage + document ingest until clinic admin acknowledges BAA
# Production: keep true with ENVIRONMENT=production (enforcement cannot be disabled via feature flags)
# Local dev: set false here OR feature-flags.json "compliance.baa_enforcement": false
BAA_ENFORCEMENT=true
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
SENTRY_DSN=
ENVIRONMENT=development
DEBUG=false
# Log policy metadata (enforce retention/access at aggregator — Railway, Grafana Cloud, etc.)
LOG_RETENTION_DAYS=30
LOG_ACCESS_CLASS=restricted_ops

# Observability (Grafana Cloud scrapes GET /metrics)
# SENTRY_DSN is listed above — PHI scrubbed before upload
