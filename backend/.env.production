# Production template — placeholders only (never commit real secrets).
# Set real values in Railway/Vercel dashboard secrets, or in backend/.env (gitignored)
# for local production simulation via `make prod`.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
FRONTEND_ORIGIN=https://your-app.vercel.app

# Prefer Upstash in production (TLS)
UPSTASH_REDIS_URL=rediss://default:your-upstash-token@your-endpoint.upstash.io:6379
REDIS_URL=

OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_ZERO_DATA_RETENTION=true

GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

SENTRY_DSN=
ENVIRONMENT=production
DEBUG=false
