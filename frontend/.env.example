# See .env.development for local dev. Copy to .env.production for prod builds
# (gitignored) or set the same keys in Vercel environment variables.
# Quick start: cp .env.development .env.local  &&  fill in your Supabase keys

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_USE_TRIAGE_WS=0
