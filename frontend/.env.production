# Production — loaded automatically by `npm run build` and `npm run start`
# For local production simulation use `npm run prod`
# Override secrets via .env.local (gitignored) when testing locally.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ENVIRONMENT=production
NEXT_PUBLIC_USE_TRIAGE_WS=0
